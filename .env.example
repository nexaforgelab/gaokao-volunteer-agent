# 高考志愿填报 Agent 系统环境变量示例
# 复制为 .env 并按需修改

# SQLite 数据库路径（默认 sqlite:///gaokao.db）
GAOKAO_DB_PATH=sqlite:///./out/gaokao.db

# 输出目录
GAOKAO_OUTPUT_DIR=./out

# 日志级别
GAOKAO_LOG_LEVEL=INFO

# 是否允许联网抓取官方数据（默认 false；启用需自行确保合规）
GAOKAO_ALLOW_NETWORK=false

# 默认风险偏好：conservative | balanced | aggressive
GAOKAO_RISK_PREFERENCE=conservative
